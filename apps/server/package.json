{
  "name": "@app/server",
  "version": "0.3.1",
  "private": true,
  "license": "AGPL-3.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun dist/index.js",
    "build": "tsc",
    "typecheck": "bunx tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint --fix .",
    "format": "oxfmt --write .",
    "validate": "echo 'validate: not yet implemented'"
  },
  "dependencies": {
    "@app/core": "workspace:*",
    "@app/logger": "workspace:*",
    "@app/shared": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@openfeature/server-sdk": "^1.20.2",
    "ai": "^6.0.156",
    "hono": "^4.12.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}