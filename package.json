{
  "name": "calca",
  "private": true,
  "version": "0.3.0",
  "description": "AI design tool with infinite canvas — vibe coding for design",
  "license": "AGPL-3.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "platforms/*"
  ],
  "scripts": {
    "dev-web": "bun --cwd apps/web dev",
    "dev-desktop": "cd platforms/desktop && bun run dev:all",
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:e2e": "gauge run e2e/specs",
    "test:e2e:spec": "gauge run",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "validate": "bun scripts/validate.ts",
    "package:desktop": "cd platforms/desktop && bun run build:full",
    "build:desktop": "cd platforms/desktop && bun run build:web",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@types/react-dom": "^19.2.3",
    "gauge-ts": "^0.3.6",
    "jsdom": "^29.0.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.4.0",
    "vitest": "^4.1.5"
  },
  "simple-git-hooks": {
    "commit-msg": "bunx commitlint --edit $1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.2.10",
  "dependencies": {
    "@ai-sdk/provider-utils": "^4.0.23",
    "@inlang/paraglide-js-adapter-vite": "^1.2.40",
    "@mastra/ai-sdk": "^1.4.0",
    "@mastra/core": "^1.25.0",
    "type-fest": "^5.6.0"
  }
}