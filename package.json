{
  "name": "gosto",
  "private": true,
  "version": "0.1.0",
  "description": "AI design tool with infinite canvas — vibe coding for design",
  "license": "AGPL-3.0-only",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev-web": "portless run next dev",
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:e2e": "gauge run e2e/specs",
    "test:e2e:spec": "gauge run",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "validate": "bun scripts/validate.ts",
    "clean": "turbo clean"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/google": "^3.0.61",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "ai": "^6.0.156",
    "html-to-image": "^1.11.13",
    "html2canvas-pro": "^1.6.7",
    "jotai": "^2.19.1",
    "lucide-react": "^1.8.0",
    "next": "^16.1.6",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "gauge-ts": "^0.3.6",
    "portless": "^0.10.1",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.4.0",
    "vitest": "^4.1.4"
  },
  "simple-git-hooks": {
    "commit-msg": "bunx commitlint --edit $1"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "packageManager": "bun@1.2.10"
}