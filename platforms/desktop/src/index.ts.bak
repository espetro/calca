// @ts-nocheck - Electrobun types have issues, but the API works at runtime
console.log("[DEBUG] index.ts loading - before imports");
import { dirname } from "path";

import { initLogger, getLogger } from "./logger";
import { VITE_DEV_URL } from "./constants";
import { versionInfo } from "./version";
import { setupApplicationMenu } from "./menu";
import { waitForServer, startServer, setServerDev, isServerDev, desktopServerOrigin } from "./server";
import { setupDatabaseDirectory } from "./database";
import { createWindow } from "./window";
import { checkAndNotify } from "./updater";
import { Updater } from "electrobun/bun";

const log = getLogger(["calca", "desktop"]);

declare global {
	interface GlobalThis {
		__CALCA_UPDATE_AVAILABLE__?: boolean;
		__CALCA_UPDATE_VERSION__?: string;
	}
}

async function main(): Promise<void> {
	const macOSDir = dirname(process.argv0);
	process.chdir(macOSDir);

	console.log("[DEBUG] Before initLogger");
	await initLogger();
	console.log("[DEBUG] After initLogger");

	const startupTimer = { start: Date.now() };
	console.log("[DEBUG] Before log.info");
	log.info`Starting Calca v${versionInfo.version}`;
	console.log("[DEBUG] After log.info");

	const channel = await Updater.localInfo.channel().catch(() => "unknown");
	const devMode = channel === "dev";
	setServerDev(devMode);
	log.info`Channel: ${channel} (${devMode ? "development" : "production"})`;

	setupDatabaseDirectory();
	setupApplicationMenu();

	if (devMode) {
		log.debug`Waiting for Vite dev server at ${VITE_DEV_URL}...`;
		await waitForServer(`${VITE_DEV_URL}/`, 60000).catch((e) => {
			log.error`Vite dev server not available: ${e}`;
		});
		startServer();
		createWindow(VITE_DEV_URL, desktopServerOrigin);
		log.info`Desktop server at ${desktopServerOrigin}`;
	} else {
		startServer();
		log.info`Server running on ${desktopServerOrigin}`;
		await waitForServer(`${desktopServerOrigin}/health`, 10000).catch((e) => {
			log.error`Health check failed: ${e}`;
		});
		console.log("[DEBUG] About to create window");
		await new Promise(r => setTimeout(r, 1000));
		console.log("[DEBUG] Creating window after delay");
		createWindow(desktopServerOrigin, desktopServerOrigin);
	}

	checkAndNotify();
	setInterval(checkAndNotify, 60 * 60 * 1000);

	const elapsed = Date.now() - startupTimer.start;
	log.debug`Startup completed in ${elapsed}ms`;
}

main().catch((e) => {
	// Fallback to console if logger failed to initialize
	// eslint-disable-next-line no-console
	console.error("[desktop] Fatal error:", e);
	process.exit(1);
});
