{
  "name": "@app/electrobun",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "web-dev": "bun run --cwd ../../apps/web dev",
    "electrobun-watch": "electrobun dev --watch",
    "dev:desktop": "bun run --parallel web-dev electrobun-watch",
    "build:desktop": "bun run scripts/build.ts",
    "verify": "bun run scripts/verify.ts",
    "clean": "rm -rf build artifacts Resources/web"
  },
  "dependencies": {
    "@app/server": "workspace:*",
    "@logtape/file": "^2.0.5",
    "@logtape/logtape": "^2.0.5",
    "electrobun": "1.16.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/fs-extra": "^11",
    "fs-extra": "^11.3.4",
    "typescript": "^6.0.3"
  }
}