{
  "name": "@app/electrobun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electrobun dev --watch",
    "dev:web": "cd ../.. && bun run dev",
    "dev:all": "bash scripts/dev.sh",
    "build:web": "cd ../.. && bun run --filter=@app/web build",
    "build": "bun run scripts/build.sh",
    "package": "electrobun package",
    "build:full": "bun run build:web && electrobun package",
    "clean": "rm -rf build artifacts Resources/web"
  },
  "dependencies": {
    "@app/server": "workspace:*",
    "electrobun": "latest"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}