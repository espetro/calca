{
  "name": "@app/electrobun",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "echo 'dev: electrobun desktop app not yet ready for turbo dev'",
    "dev:web": "cd ../.. && bun run dev",
    "dev:all": "bun run dev:web & bun run dev",
    "build:web": "cd ../.. && bun run --filter=@app/web build",
    "package": "electrobun package",
    "build:full": "bun run build:web && electrobun package",
    "clean": "rm -rf build artifacts Resources/web"
  },
  "dependencies": {
    "@app/server": "workspace:*",
    "electrobun": "latest"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}